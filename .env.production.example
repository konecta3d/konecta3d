# =====================================================
# KONECTA3D - VARIABLES DE ENTORNO PARA PRODUCCIÓN
# =====================================================

# URL de Supabase (reemplaza con tu proyecto de producción)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (Anonymous Key) - Safe para cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# IMPORTANTE: NO exponer la Service Role Key en el cliente
# Esta solo se usa en server-side (API routes)
# En Vercel, configurarla como variable de servidor (Server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================================
# CÓMO CONFIGURAR EN VERCEL:
# =====================================================

# 1. Ve a tu proyecto en Vercel
# 2. Settings > Environment Variables
# 3. Añade cada variable:
#
#    NEXT_PUBLIC_SUPABASE_URL     -> Production
#    NEXT_PUBLIC_SUPABASE_ANON_KEY -> Production  
#    SUPABASE_SERVICE_ROLE_KEY     -> Production (marcar como secret)
#
# NOTA: La Service Role Key debe mantenerse privada!
# Solo se usa en las API routes del servidor.
