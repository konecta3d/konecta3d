# ============================================================
# KONECTA3D — ENTORNO LOCAL / DEV
# ============================================================
# Copia este archivo como .env.local y rellena las claves
# del proyecto konecta3d-DEV de Supabase (NO el de producción).
#
# Dónde encontrar estos valores:
#   supabase.com → proyecto konecta3d-dev
#   → Project Settings → API
# ============================================================

# URL del proyecto DEV
NEXT_PUBLIC_SUPABASE_URL=https://[tu-proyecto-dev].supabase.co

# Clave pública (anon key) del proyecto DEV
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key-dev]

# Clave de servicio del proyecto DEV — solo en server-side, nunca al cliente
SUPABASE_SERVICE_ROLE_KEY=[service-role-key-dev]

# Email del admin en el proyecto DEV
NEXT_PUBLIC_ADMIN_EMAIL=admin@konecta3d-dev.com

# OpenAI (misma clave que producción está bien)
OPENAI_API_KEY=[tu-openai-key]

# Chromium para generación de PDF en Vercel
CHROMIUM_REMOTE_EXEC_URL=https://github.com/Sparticuz/chromium/releases/download/v147.0.0/chromium-v147.0.0-pack.tar

# Chrome local para desarrollo (descomenta y ajusta la ruta si lo necesitas)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
